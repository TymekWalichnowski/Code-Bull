; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Card Bull"
run/main_scene="uid://b85gmj83uys81"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

PlayerDeckGlobal="*res://scenes/globals/player_deck_global.tscn"
SproutyDialogs="*res://addons/sprouty_dialogs/sprouty_dialogs_manager.gd"
AudioManager="*res://scripts/globals/audio_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="canvas_items"
window/vsync/vsync_mode=0

[editor_plugins]

enabled=PackedStringArray("res://addons/sprouty_dialogs/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/textures/cards/": "gray",
"res://objects/cards/": "yellow",
"res://objects/cards/actions/": "orange",
"res://objects/cards/animations/": "green",
"res://objects/cards/statuses/": "red",
"res://objects/cards_passive/": "teal",
"res://objects/tags/": "gray",
"res://objects/tokens/": "red",
"res://resources/": "pink",
"res://scenes/": "blue",
"res://scripts/": "purple"
}

[graph_dialogs]

general/input/continue_input_action="dialogs_continue_action"
general/defaults/default_dialog_box=1568908516147823318
general/defaults/default_portrait_scene=5003988533333559685
general/canvas/dialog_box_canvas_layer=2
general/canvas/portraits_canvas_layer=1
general/custom/use_custom_event_nodes=false
general/custom/custom_event_nodes_folder=""
general/custom/custom_event_interpreter=-1
text/default_typing_speed=0.05
text/open_url_on_meta_tag_click=true
text/display/new_line_as_new_dialog=true
text/display/split_dialog_by_max_characters=false
text/display/max_characters=0
text/skip/allow_skip_text_reveal=true
text/skip/can_skip_delay=0.1
text/skip/continue_delay=0.1
translation/enable_translations=false
translation/csv_files/use_csv_files=false
translation/csv_files/csv_translations_folder=""
translation/csv_files/fallback_to_resource=true
translation/characters/translate_character_names=false
translation/characters/use_csv_for_character_names=false
translation/characters/character_names_csv=-1
translation/localization/default_locale="en"
translation/localization/locales=["en"]
variables/variables={}
internal/play_dialog_path="res://Assets/dialogue/dialogues/test_dialogue.tres"
internal/play_start_id="FIRST"

[input]

left_click={
"deadzone": 0.2,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":0,"position":Vector2(0, 0),"global_position":Vector2(0, 0),"factor":1.0,"button_index":1,"canceled":false,"pressed":false,"double_click":false,"script":null)
]
}
